#!/bin/bash

# 오류 발생 시 스크립트 중단
set -e

echo "===== Azure AD RBAC 설정 시작 ====="

# 환경 변수 설정
SUBSCRIPTION_ID=$(az account show --query id -o tsv)
TENANT_ID=$(az account show --query tenantId -o tsv)
LOCATION="koreacentral"
RESOURCE_GROUP_HUB="rg-hub-aks-workshop"
RESOURCE_GROUP_SPOKE="rg-spoke-aks-workshop"
AKS_CLUSTER_NAME="private-aks"

# Azure AD 그룹 생성
echo "Azure AD 그룹 생성 중..."

# AKS 관리자 그룹
AKS_ADMIN_GROUP_NAME="aks-admin-group"
AKS_ADMIN_GROUP_ID=$(az ad group create --display-name $AKS_ADMIN_GROUP_NAME --mail-nickname $AKS_ADMIN_GROUP_NAME --query id -o tsv)
echo "AKS 관리자 그룹 ID: $AKS_ADMIN_GROUP_ID"

# AKS 개발자 그룹
AKS_DEV_GROUP_NAME="aks-dev-group"
AKS_DEV_GROUP_ID=$(az ad group create --display-name $AKS_DEV_GROUP_NAME --mail-nickname $AKS_DEV_GROUP_NAME --query id -o tsv)
echo "AKS 개발자 그룹 ID: $AKS_DEV_GROUP_ID"

# AKS 운영자 그룹
AKS_OPS_GROUP_NAME="aks-ops-group"
AKS_OPS_GROUP_ID=$(az ad group create --display-name $AKS_OPS_GROUP_NAME --mail-nickname $AKS_OPS_GROUP_NAME --query id -o tsv)
echo "AKS 운영자 그룹 ID: $AKS_OPS_GROUP_ID"

# ACR 관리자 그룹
ACR_ADMIN_GROUP_NAME="acr-admin-group"
ACR_ADMIN_GROUP_ID=$(az ad group create --display-name $ACR_ADMIN_GROUP_NAME --mail-nickname $ACR_ADMIN_GROUP_NAME --query id -o tsv)
echo "ACR 관리자 그룹 ID: $ACR_ADMIN_GROUP_ID"

# KeyVault 관리자 그룹
KV_ADMIN_GROUP_NAME="kv-admin-group"
KV_ADMIN_GROUP_ID=$(az ad group create --display-name $KV_ADMIN_GROUP_NAME --mail-nickname $KV_ADMIN_GROUP_NAME --query id -o tsv)
echo "KeyVault 관리자 그룹 ID: $KV_ADMIN_GROUP_ID"

# terraform.tfvars 파일 업데이트
echo "terraform.tfvars 파일 업데이트 중..."

# 파일이 존재하는지 확인
if [ -f "../terraform.tfvars" ]; then
  # 기존 파일 백업
  cp ../terraform.tfvars ../terraform.tfvars.bak
  
  # Azure AD 그룹 ID 업데이트
  sed -i "s/aks_admin_group_object_ids = \[\]/aks_admin_group_object_ids = [\"$AKS_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
  sed -i "s/aks_dev_group_object_ids = \[\]/aks_dev_group_object_ids = [\"$AKS_DEV_GROUP_ID\"]/g" ../terraform.tfvars
  sed -i "s/aks_ops_group_object_ids = \[\]/aks_ops_group_object_ids = [\"$AKS_OPS_GROUP_ID\"]/g" ../terraform.tfvars
  sed -i "s/acr_admin_group_object_ids = \[\]/acr_admin_group_object_ids = [\"$ACR_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
  sed -i "s/keyvault_admin_object_ids = \[\]/keyvault_admin_object_ids = [\"$KV_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
  
  echo "terraform.tfvars 파일이 업데이트되었습니다."
else
  echo "terraform.tfvars 파일이 존재하지 않습니다. 샘플 파일을 복사하고 업데이트하세요."
  if [ -f "../terraform.tfvars.example" ]; then
    cp ../terraform.tfvars.example ../terraform.tfvars
    
    # Azure AD 그룹 ID 업데이트
    sed -i "s/aks_admin_group_object_ids = \[\]/aks_admin_group_object_ids = [\"$AKS_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
    sed -i "s/aks_dev_group_object_ids = \[\]/aks_dev_group_object_ids = [\"$AKS_DEV_GROUP_ID\"]/g" ../terraform.tfvars
    sed -i "s/aks_ops_group_object_ids = \[\]/aks_ops_group_object_ids = [\"$AKS_OPS_GROUP_ID\"]/g" ../terraform.tfvars
    sed -i "s/acr_admin_group_object_ids = \[\]/acr_admin_group_object_ids = [\"$ACR_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
    sed -i "s/keyvault_admin_object_ids = \[\]/keyvault_admin_object_ids = [\"$KV_ADMIN_GROUP_ID\"]/g" ../terraform.tfvars
    
    echo "terraform.tfvars 파일이 생성되고 업데이트되었습니다."
  else
    echo "terraform.tfvars.example 파일도 존재하지 않습니다. 먼저 샘플 파일을 생성하세요."
  fi
fi

echo "===== Azure AD RBAC 설정 완료 ====="
echo "다음 그룹 ID를 기록해두세요:"
echo "AKS 관리자 그룹 ID: $AKS_ADMIN_GROUP_ID"
echo "AKS 개발자 그룹 ID: $AKS_DEV_GROUP_ID"
echo "AKS 운영자 그룹 ID: $AKS_OPS_GROUP_ID"
echo "ACR 관리자 그룹 ID: $ACR_ADMIN_GROUP_ID"
echo "KeyVault 관리자 그룹 ID: $KV_ADMIN_GROUP_ID" 