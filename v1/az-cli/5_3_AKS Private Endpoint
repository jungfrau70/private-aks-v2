## **6. 오류 처리 및 문제 해결**

```bash
# DNS 설정 문제 해결
echo "DNS 설정에 문제가 있는 경우 Jumpbox에서 다음 명령어를 실행하세요:"
echo "sudo rm /etc/resolv.conf"
echo "sudo bash -c 'echo \"nameserver 168.63.129.16\" > /etc/resolv.conf'"
echo "sudo bash -c 'echo \"search privatelink.$LOCATION.azmk8s.io\" >> /etc/resolv.conf'"

# Private DNS 레코드 확인
echo "Private DNS 레코드를 확인하려면 다음 명령어를 실행하세요:"
echo "az network private-dns record-set a list --resource-group $SPOKE_RG --zone-name $PRIVATE_DNS_ZONE --query \"[].{Name:name, Records:aRecords[].ipv4Address, TTL:ttl}\" --output table"

# AKS 자동 생성된 Private Endpoint 확인
echo "AKS 자동 생성된 Private Endpoint 확인:"
echo "az network nic list --resource-group $SPOKE_RG --query \"[?contains(name, 'kube-apiserver')].{Name:name, PrivateIP:ipConfigurations[0].privateIPAddress}\" --output table"

# AKS 클러스터 상태 확인
echo "AKS 클러스터 상태를 확인하려면 다음 명령어를 실행하세요:"
echo "az aks show --resource-group $SPOKE_RG --name $AKS_CLUSTER_NAME --query provisioningState -o tsv"

# 네트워크 연결 테스트
echo "네트워크 연결을 테스트하려면 Jumpbox에서 다음 명령어를 실행하세요:"
echo "ping $PRIVATE_IP"
```

