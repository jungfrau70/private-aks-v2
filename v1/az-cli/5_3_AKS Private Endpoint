## **4. Private Endpoint 및 DNS 설정**
Jumpbox에서 Private AKS의 Private Endpoint를 DNS로 조회할 수 있도록 설정합니다.

```bash
# 리전에 맞는 Private DNS Zone 이름 설정
PRIVATE_DNS_ZONE="privatelink.$LOCATION.azmk8s.io"
echo "Private DNS Zone: $PRIVATE_DNS_ZONE"

# Private DNS Zone 존재 여부 확인 후 생성
az network private-dns zone show --resource-group $SPOKE_RG --name $PRIVATE_DNS_ZONE > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Private DNS Zone 생성 중..."
  az network private-dns zone create \
    --resource-group $SPOKE_RG \
    --name $PRIVATE_DNS_ZONE
else
  echo "Private DNS Zone이 이미 존재합니다."
fi

# Spoke VNet을 Private DNS Zone에 연결 (존재 여부 확인 후)
az network private-dns link vnet show --resource-group $SPOKE_RG --zone-name $PRIVATE_DNS_ZONE --name "SpokeVnetDNSLink" > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Spoke VNet을 Private DNS Zone에 연결 중..."
  az network private-dns link vnet create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "SpokeVnetDNSLink" \
    --virtual-network $SPOKE_VNET_NAME \
    --registration-enabled false
else
  echo "Spoke VNet DNS 링크가 이미 존재합니다."
fi

# Hub VNet을 Private DNS Zone에 연결 (존재 여부 확인 후)
az network private-dns link vnet show --resource-group $SPOKE_RG --zone-name $PRIVATE_DNS_ZONE --name "HubVnetDNSLink" > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Hub VNet을 Private DNS Zone에 연결 중..."
  az network private-dns link vnet create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "HubVnetDNSLink" \
    --virtual-network $(az network vnet show -g $HUB_RG -n $HUB_VNET_NAME --query id -o tsv) \
    --registration-enabled false
else
  echo "Hub VNet DNS 링크가 이미 존재합니다."
fi

# AKS 자동 생성된 Private Endpoint NIC 찾기
echo "AKS 자동 생성된 Private Endpoint NIC 찾기..."
PRIVATE_ENDPOINT_NIC=$(az network nic list \
  --resource-group $SPOKE_RG \
  --query "[?contains(name, 'kube-apiserver')].id" \
  --output tsv)

if [ -z "$PRIVATE_ENDPOINT_NIC" ]; then
  echo "경고: 자동 생성된 AKS Private Endpoint NIC를 찾을 수 없습니다."
  exit 1
fi

echo "Private Endpoint NIC: $PRIVATE_ENDPOINT_NIC"

# Private Endpoint의 Private IP 주소 가져오기
PRIVATE_IP=$(az network nic show \
  --ids $PRIVATE_ENDPOINT_NIC \
  --query "ipConfigurations[0].privateIPAddress" \
  --output tsv)

echo "Private Endpoint IP: $PRIVATE_IP"

# AKS FQDN에서 호스트 이름 추출
FULL_PREFIX=$(echo $AKS_PRIVATE_FQDN | cut -d'.' -f1-2)
echo "AKS Host Prefix: $FULL_PREFIX"

# Private DNS 레코드 존재 여부 확인 후 추가
az network private-dns record-set a show --resource-group $SPOKE_RG --zone-name $PRIVATE_DNS_ZONE --name "$FULL_PREFIX" > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Private DNS A 레코드 생성 중..."
  az network private-dns record-set a create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "$FULL_PREFIX" \
    --ttl 3600

  az network private-dns record-set a add-record \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --record-set-name "$FULL_PREFIX" \
    --ipv4-address $PRIVATE_IP
else
  echo "Private DNS A 레코드가 이미 존재합니다."
  
  # 기존 레코드의 IP 주소 확인
  EXISTING_IP=$(az network private-dns record-set a show \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "$FULL_PREFIX" \
    --query "aRecords[0].ipv4Address" \
    --output tsv)
  
  # IP 주소가 다르면 업데이트
  if [ "$EXISTING_IP" != "$PRIVATE_IP" ]; then
    echo "Private DNS A 레코드 업데이트 중..."
    az network private-dns record-set a update \
      --resource-group $SPOKE_RG \
      --zone-name $PRIVATE_DNS_ZONE \
      --name "$FULL_PREFIX" \
      --set "aRecords[0].ipv4Address=$PRIVATE_IP"
  fi
fi
```

