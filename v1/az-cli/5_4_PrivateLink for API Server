  echo "Jumpbox VM에서 다음 명령어를 실행하세요:"
  echo "kubectl get nodes"
fi
```

## **6️⃣ 문제 해결**

```bash
# AKS 자동 생성된 Private Endpoint NIC 확인
echo "AKS 자동 생성된 Private Endpoint NIC 확인 중..."
az network nic list \
    --resource-group $SPOKE_RG \
    --query "[?contains(name, 'kube-apiserver')].{Name:name, PrivateIP:ipConfigurations[0].privateIPAddress, ProvisioningState:provisioningState}" \
    --output table

# AKS 클러스터 상태 확인
echo "AKS 클러스터 상태 확인 중..."
az aks show \
    --resource-group $SPOKE_RG \
    --name $AKS_CLUSTER_NAME \
    --query "{Name:name, ProvisioningState:provisioningState, PrivateFQDN:privateFqdn}" \
    --output table

# DNS 해결 테스트 안내
echo "Jumpbox VM에서 DNS 해결 테스트를 위해 다음 명령어를 실행하세요:"
echo "dig $AKS_FQDN"

# 네트워크 연결 테스트 안내
echo "Jumpbox VM에서 네트워크 연결 테스트를 위해 다음 명령어를 실행하세요:"
echo "ping $PRIVATE_IP"
echo "nc -zv $PRIVATE_IP 443"

# DNS 서버 확인
echo "Jumpbox VM에서 DNS 서버 확인을 위해 다음 명령어를 실행하세요:"
echo "cat /etc/resolv.conf"

# nslookup 테스트
echo "Jumpbox VM에서 nslookup 테스트를 위해 다음 명령어를 실행하세요:"
echo "nslookup $AKS_FQDN"

# dig 테스트 (더 자세한 정보 제공)
echo "Jumpbox VM에서 dig 테스트를 위해 다음 명령어를 실행하세요:"
echo "dig $AKS_FQDN"

# Private DNS Zone 레코드 확인
echo "Private DNS Zone 레코드 확인을 위해 다음 명령어를 실행하세요:"
echo "az network private-dns record-set a list \
  --resource-group $SPOKE_RG \
  --zone-name $PRIVATE_DNS_ZONE \
  --query \"[].{Name:name, Records:aRecords[].ipv4Address, TTL:ttl}\" \
  --output table"

# 네트워크 연결 테스트
echo "Jumpbox VM에서 네트워크 연결 테스트를 위해 다음 명령어를 실행하세요:"
echo "nc -zv $PRIVATE_IP 443"
```

## **7️⃣ Terraform 환경과의 통합**

```bash
# Terraform 상태 확인
echo "Terraform 상태를 확인하려면 v2 디렉토리에서 다음 명령어를 실행하세요:"
echo "cd ../../v2 && terraform state list | grep -E 'aks|private_dns'"

# Terraform으로 생성된 리소스 가져오기
echo "Terraform으로 생성된 리소스를 확인하려면 다음 명령어를 실행하세요:"
echo "cd ../../v2 && terraform output"

# Terraform 상태와 동기화
echo "이 스크립트로 생성한 리소스를 Terraform 상태와 동기화하려면 다음 명령어를 실행하세요:"
echo "cd ../../v2 && terraform import module.aks_clusters.azurerm_private_dns_zone.aks_private_dns[0] /subscriptions/$SUBSCRIPTION_ID/resourceGroups/$SPOKE_RG/providers/Microsoft.Network/privateDnsZones/$PRIVATE_DNS_ZONE"
```

## **8️⃣ Jumpbox VM에 DNS 설정 스크립트 생성 및 실행**

```bash
# Jumpbox VM에 DNS 설정 스크립트 생성 및 실행
echo "Jumpbox VM에 DNS 설정 스크립트 생성 및 실행 중..."
SSH_COMMAND="sudo bash -c 'echo \"nameserver 168.63.129.16\" > /etc/resolv.conf && echo \"search privatelink.$LOCATION.azmk8s.io\" >> /etc/resolv.conf'"

# 스크립트 파일 생성
cat > setup_dns.sh << EOF
#!/bin/bash
az vm run-command invoke \
  --resource-group $HUB_RG \
  --name $JUMPBOX_VM_NAME \
  --command-id RunShellScript \
  --scripts "$SSH_COMMAND"
EOF

# 스크립트 실행 권한 부여 및 실행
chmod +x setup_dns.sh
./setup_dns.sh
```

