## **1️⃣ AKS Private Link 확인**

```bash
# AKS 클러스터 존재 여부 확인
az aks show --resource-group $SPOKE_RG --name $AKS_CLUSTER_NAME > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "오류: AKS 클러스터가 존재하지 않습니다. 먼저 5_3_AKS Private Endpoint 문서의 단계를 완료하세요."
  exit 1
fi

# AKS 자동 생성된 Private Endpoint NIC 찾기
echo "AKS 자동 생성된 Private Endpoint NIC 찾기..."
PRIVATE_ENDPOINT_NIC=$(az network nic list \
  --resource-group $SPOKE_RG \
  --query "[?contains(name, 'kube-apiserver')].id" \
  --output tsv)

if [ -z "$PRIVATE_ENDPOINT_NIC" ]; then
  echo "경고: 자동 생성된 AKS Private Endpoint NIC를 찾을 수 없습니다."
  exit 1
fi

echo "Private Endpoint NIC: $PRIVATE_ENDPOINT_NIC"

# Private Endpoint NIC 상태 확인
echo "Private Endpoint NIC 상태 확인 중..."
az network nic show \
  --ids $PRIVATE_ENDPOINT_NIC \
  --query "provisioningState" \
  --output tsv
```

## **2️⃣ Private IP 및 FQDN 확인**

```bash
# Private IP 주소 조회
PRIVATE_IP=$(az network nic show \
  --ids $PRIVATE_ENDPOINT_NIC \
  --query "ipConfigurations[0].privateIPAddress" \
  --output tsv)

echo "Private IP: $PRIVATE_IP"

# AKS API 서버의 FQDN 확인
AKS_FQDN=$(az aks show \
    --resource-group $SPOKE_RG \
    --name $AKS_CLUSTER_NAME \
    --query 'privateFqdn' \
    --output tsv)

echo "AKS API Server FQDN: $AKS_FQDN"

# FQDN이 비어있는지 확인
if [ -z "$AKS_FQDN" ]; then
  echo "오류: AKS API 서버의 FQDN을 가져올 수 없습니다. AKS 클러스터가 Private 모드로 설정되어 있는지 확인하세요."
  exit 1
fi
```

## **3️⃣ DNS 설정**

```bash
# Private DNS Zone 생성 (이미 생성되어 있다면 이 단계는 건너뜁니다)
PRIVATE_DNS_ZONE="privatelink.$LOCATION.azmk8s.io"
echo "Private DNS Zone: $PRIVATE_DNS_ZONE"

az network private-dns zone show \
    --resource-group $SPOKE_RG \
    --name $PRIVATE_DNS_ZONE \
    --query name -o tsv > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Private DNS Zone 생성 중..."
  az network private-dns zone create \
    --resource-group $SPOKE_RG \
    --name $PRIVATE_DNS_ZONE
else
  echo "Private DNS Zone이 이미 존재합니다."
fi

# Jumpbox VM 존재 여부 확인
az vm show --resource-group $HUB_RG --name $JUMPBOX_VM_NAME > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "경고: Jumpbox VM이 존재하지 않습니다. DNS 설정을 위해 Jumpbox VM이 필요합니다."
else
  # Jumpbox VM의 공용 IP 주소 가져오기
  JUMPBOX_PUBLIC_IP=$(az vm show \
    --resource-group $HUB_RG \
    --name $JUMPBOX_VM_NAME \
    --show-details \
    --query publicIps -o tsv)
  
  echo "Jumpbox VM Public IP: $JUMPBOX_PUBLIC_IP"
  
  # Jumpbox VM에서 DNS 설정 변경 안내
  echo "Jumpbox VM에서 다음 명령어를 실행하세요:"
  echo "ssh azureuser@$JUMPBOX_PUBLIC_IP"
  echo "sudo rm /etc/resolv.conf"
  echo "sudo bash -c 'echo \"nameserver 168.63.129.16\" > /etc/resolv.conf'"
  echo "sudo bash -c 'echo \"search privatelink.$LOCATION.azmk8s.io\" >> /etc/resolv.conf'"
fi

# Private DNS 레코드 추가
FULL_PREFIX=$(echo $AKS_FQDN | cut -d'.' -f1-2)
echo "Full Prefix: $FULL_PREFIX"

# A 레코드가 이미 존재하는지 확인
az network private-dns record-set a show \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "$FULL_PREFIX" \
    --query name -o tsv > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Private DNS A 레코드 생성 중..."
  az network private-dns record-set a create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "$FULL_PREFIX" \
    --ttl 3600
else
  echo "Private DNS A 레코드가 이미 존재합니다."
fi

# A 레코드에 IP 추가 또는 업데이트
EXISTING_IP=$(az network private-dns record-set a show \
  --resource-group $SPOKE_RG \
  --zone-name $PRIVATE_DNS_ZONE \
  --name "$FULL_PREFIX" \
  --query "aRecords[0].ipv4Address" \
  --output tsv 2>/dev/null)

if [ -z "$EXISTING_IP" ] || [ "$EXISTING_IP" != "$PRIVATE_IP" ]; then
  echo "Private DNS A 레코드에 IP 추가 또는 업데이트 중..."
  az network private-dns record-set a update \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "$FULL_PREFIX" \
    --set "aRecords=[{\"ipv4Address\":\"$PRIVATE_IP\"}]"
else
  echo "Private DNS A 레코드의 IP가 이미 올바르게 설정되어 있습니다."
fi

# Hub VNet에 Private DNS Zone 링크 추가 (이미 생성되어 있다면 이 단계는 건너뜁니다)
az network private-dns link vnet show \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "hubvnetlink" \
    --query name -o tsv > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Hub VNet에 Private DNS Zone 링크 추가 중..."
  az network private-dns link vnet create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "hubvnetlink" \
    --virtual-network $(az network vnet show -g $HUB_RG -n $HUB_VNET_NAME --query id -o tsv) \
    --registration-enabled false
else
  echo "Hub VNet Private DNS Zone 링크가 이미 존재합니다."
fi

# Spoke VNet에 Private DNS Zone 링크 추가 (이미 생성되어 있다면 이 단계는 건너뜁니다)
az network private-dns link vnet show \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "spokevnetlink" \
    --query name -o tsv > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "Spoke VNet에 Private DNS Zone 링크 추가 중..."
  az network private-dns link vnet create \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --name "spokevnetlink" \
    --virtual-network $(az network vnet show -g $SPOKE_RG -n $SPOKE_VNET_NAME --query id -o tsv) \
    --registration-enabled false
else
  echo "Spoke VNet Private DNS Zone 링크가 이미 존재합니다."
fi
```

## **4️⃣ 설정 확인**

```bash
# Private DNS Zone 확인
echo "Private DNS Zone 목록 확인 중..."
az network private-dns zone list \
    --resource-group $SPOKE_RG \
    --output table

# Private DNS Zone 링크 확인
echo "Private DNS Zone 링크 확인 중..."
az network private-dns link vnet list \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --output table

# DNS 레코드 확인
echo "DNS 레코드 확인 중..."
az network private-dns record-set a list \
    --resource-group $SPOKE_RG \
    --zone-name $PRIVATE_DNS_ZONE \
    --query "[].{Name:name, Records:aRecords[].ipv4Address, TTL:ttl}" \
    --output table

# AKS 자동 생성된 Private Endpoint NIC 확인
echo "AKS 자동 생성된 Private Endpoint NIC 확인 중..."
az network nic list \
    --resource-group $SPOKE_RG \
    --query "[?contains(name, 'kube-apiserver')].{Name:name, PrivateIP:ipConfigurations[0].privateIPAddress}" \
    --output table
```

## **5️⃣ 연결 테스트**

```bash
# Jumpbox VM 존재 여부 확인
az vm show --resource-group $HUB_RG --name $JUMPBOX_VM_NAME > /dev/null 2>&1
if [ $? -ne 0 ]; then
  echo "경고: Jumpbox VM이 존재하지 않습니다. 연결 테스트를 위해 Jumpbox VM이 필요합니다."
else
  # Jumpbox VM의 공용 IP 주소 가져오기
  JUMPBOX_PUBLIC_IP=$(az vm show \
    --resource-group $HUB_RG \
    --name $JUMPBOX_VM_NAME \
    --show-details \
    --query publicIps -o tsv)
  
  echo "Jumpbox VM에 SSH로 접속하려면 다음 명령을 실행하세요:"
  echo "ssh azureuser@$JUMPBOX_PUBLIC_IP"
  
  # Jumpbox VM에서 AKS API 서버 FQDN 조회 테스트
  echo "Jumpbox VM에서 다음 명령어를 실행하세요:"
  echo "nslookup $AKS_FQDN"
  
  # kubeconfig 업데이트 (Jumpbox VM에서 실행)
  echo "Jumpbox VM에서 다음 명령어를 실행하세요:"
  echo "az login"
  echo "az aks get-credentials --resource-group $SPOKE_RG --name $AKS_CLUSTER_NAME --overwrite-existing"
  
